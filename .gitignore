# Root .gitignore for StudentInfo (Frontend & Backend)

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
dist-ssr/
build/
out/
.next/
.nuxt/

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# OS Files
.DS_Store
Thumbs.db
*.swp

# IDEs and Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.sublime-project
*.sublime-workspace

# Testing and Coverage
coverage/
*.lcov
.nyc_output

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.npm/

# Misc
*.tgz
.yarn-integrity
